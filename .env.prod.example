# 서버 공인 IP (OCI VM에서 확인)
SERVER_IP=1.2.3.4

# DB 패스워드 (변경 필요)
POSTGRES_PASSWORD=change_me_strong_password

# Keycloak 관리자 패스워드 (변경 필요)
KEYCLOAK_ADMIN_PASSWORD=change_me_admin_password

# Keycloak 클라이언트 시크릿 (allfolio-realm.json과 일치해야 함)
KEYCLOAK_CLIENT_SECRET=allfolio-frontend-secret

# NextAuth 시크릿 (랜덤 문자열, 32자 이상)
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_random_secret_at_least_32_chars
