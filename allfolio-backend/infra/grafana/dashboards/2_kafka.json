{
  "title": "Kafka 상태",
  "uid": "allfolio-kafka",
  "tags": ["allfolio", "kafka"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "type": "stat",
      "title": "Publish 성공률 (5m)",
      "options": { "unit": "percentunit", "colorMode": "background", "thresholds": { "steps": [
        { "color": "red",    "value": 0    },
        { "color": "yellow", "value": 0.95 },
        { "color": "green",  "value": 0.99 }
      ]}},
      "targets": [{ "expr": "rate(kafka_publish_count_total{result='success',topic='outbox.trade'}[5m]) / (rate(kafka_publish_count_total{topic='outbox.trade'}[5m]) + 1e-9)", "legendFormat": "success rate" }]
    },
    {
      "id": 2, "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "type": "stat",
      "title": "Publish 실패 (5m)",
      "options": { "colorMode": "background", "thresholds": { "steps": [
        { "color": "green",  "value": 0 },
        { "color": "yellow", "value": 1 },
        { "color": "red",    "value": 10 }
      ]}},
      "targets": [{ "expr": "increase(kafka_publish_count_total{result='fail',topic='outbox.trade'}[5m])", "legendFormat": "fail count" }]
    },
    {
      "id": 3, "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "type": "stat",
      "title": "Consumer 처리 (5m)",
      "options": { "unit": "short" },
      "targets": [{ "expr": "increase(kafka_consume_count_total{topic='outbox.trade',result='success'}[5m])", "legendFormat": "consumed" }]
    },
    {
      "id": 4, "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Kafka outbox.trade Throughput",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(kafka_publish_count_total{result='success',topic='outbox.trade'}[1m])", "legendFormat": "publish/s" },
        { "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='success'}[1m])",  "legendFormat": "consume/s" },
        { "expr": "rate(kafka_publish_count_total{result='fail',topic='outbox.trade'}[1m])",    "legendFormat": "fail/s" }
      ]
    },
    {
      "id": 5, "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Kafka Consumer Lag (JMX Exporter)",
      "description": "kafka_consumer_group_lag metric — requires kafka-exporter or JMX exporter",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "kafka_consumergroup_lag{topic='outbox.trade'}", "legendFormat": "{{partition}} lag" }
      ],
      "alert": {
        "name": "kafka_consumer_lag_high",
        "message": "Kafka consumer lag > 10000",
        "conditions": [{ "type": "query", "query": { "params": ["A", "5m", "now"] }, "reducer": { "type": "max" }, "evaluator": { "type": "gt", "params": [10000] } }]
      }
    },
    {
      "id": 6, "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "type": "timeseries",
      "title": "DLQ Kafka Throughput",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(kafka_publish_count_total{topic='dlq.trade'}[1m])",  "legendFormat": "dlq.trade" },
        { "expr": "rate(kafka_publish_count_total{topic='dlq.fetch'}[1m])",  "legendFormat": "dlq.fetch" },
        { "expr": "rate(kafka_publish_count_total{topic='dlq.dead'}[1m])",   "legendFormat": "dlq.dead" }
      ]
    }
  ]
}
