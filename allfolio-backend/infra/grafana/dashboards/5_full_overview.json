{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Allfolio Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "row",        "name": "Row",         "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["allfolio", "overview"],
  "title": "Allfolio Overview",
  "uid": "allfolio-overview-v2",
  "version": 1,
  "weekStart": "",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "broker",
        "type": "query",
        "label": "Broker",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(trade_process_count_total, broker)",
        "query": { "query": "label_values(trade_process_count_total, broker)", "refId": "A" },
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [

    {
      "id": 100, "type": "row",
      "title": "Trade Pipeline",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Trade TPS (1m)",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 3000 }
          ]
        }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(trade_process_count_total{result='success'}[1m]))",
          "legendFormat": "TPS",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Outbox PENDING",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "outbox_pending_size",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Outbox FAILED",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "outbox_failed_size",
          "legendFormat": "failed",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Outbox DEAD",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "outbox_dead_size",
          "legendFormat": "dead",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Kafka Publish 성공률 (5m)",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.95 },
            { "color": "green", "value": 0.99 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_publish_count_total{result='success',topic='outbox.trade'}[5m]) / (rate(kafka_publish_count_total{topic='outbox.trade'}[5m]) + 1e-9)",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Snapshot p95 Latency",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(snapshot_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 ms",
          "refId": "A"
        }
      ]
    },

    {
      "id": 200, "type": "row",
      "title": "Trade TPS & Outbox Status",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Trade 처리 TPS (브로커별)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(broker)(rate(trade_process_count_total{result='success',broker=~'$broker'}[1m]))",
          "legendFormat": "{{broker}} success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(broker)(rate(trade_process_count_total{result='dedup',broker=~'$broker'}[1m]))",
          "legendFormat": "{{broker}} dedup",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(broker)(rate(trade_process_count_total{result='dlq',broker=~'$broker'}[1m]))",
          "legendFormat": "{{broker}} dlq",
          "refId": "C"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Outbox 이벤트 처리 (processed/failed/dead)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "dead" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(outbox_event_count_total{result='processed'}[1m])",
          "legendFormat": "processed",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(outbox_event_count_total{result='failed'}[1m])",
          "legendFormat": "failed",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(outbox_event_count_total{result='dead'}[1m])",
          "legendFormat": "dead",
          "refId": "C"
        }
      ]
    },

    {
      "id": 300, "type": "row",
      "title": "Outbox Latency & Kafka",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Outbox 처리 레이턴시 (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(outbox_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(outbox_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(outbox_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Kafka outbox.trade Throughput",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_publish_count_total{result='success',topic='outbox.trade'}[1m])",
          "legendFormat": "publish/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_publish_count_total{result='fail',topic='outbox.trade'}[1m])",
          "legendFormat": "publish fail/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='success'}[1m])",
          "legendFormat": "consume/s",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='duplicate'}[1m])",
          "legendFormat": "duplicate/s",
          "refId": "D"
        }
      ]
    },

    {
      "id": 400, "type": "row",
      "title": "Snapshot Latency & Broker API",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Snapshot 생성 레이턴시 (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(snapshot_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(snapshot_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(snapshot_process_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Broker API 레이턴시 p95 (브로커/오퍼레이션별)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(broker,operation,le)(rate(broker_api_latency_seconds_bucket{broker=~'$broker'}[5m]))) * 1000",
          "legendFormat": "{{broker}}/{{operation}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 500, "type": "row",
      "title": "Kafka Consumer Lag & DLQ",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 40,
      "type": "timeseries",
      "title": "Kafka Consumer Lag (outbox.trade)",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "kafka_consumergroup_lag{topic='outbox.trade'}",
          "legendFormat": "partition={{partition}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "DLQ 크기 (브로커별)",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "dlq_size{queue='active',broker=~'$broker'}",
          "legendFormat": "{{broker}} active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "dlq_size{queue='dead',broker=~'$broker'}",
          "legendFormat": "{{broker}} dead",
          "refId": "B"
        }
      ]
    },

    {
      "id": 600, "type": "row",
      "title": "Kafka Consumer Process Latency",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 50,
      "type": "timeseries",
      "title": "Kafka Consumer 처리 레이턴시 (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(kafka_consumer_process_latency_seconds_bucket{topic='outbox.trade'}[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(kafka_consumer_process_latency_seconds_bucket{topic='outbox.trade'}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(kafka_consumer_process_latency_seconds_bucket{topic='outbox.trade'}[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 51,
      "type": "timeseries",
      "title": "Kafka Consumer 처리 결과 (success/fail/duplicate)",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='success'}[1m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='fail'}[1m])",
          "legendFormat": "fail",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='duplicate'}[1m])",
          "legendFormat": "duplicate",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(kafka_consume_count_total{topic='outbox.trade',result='deserialize_failed'}[1m])",
          "legendFormat": "deserialize_failed",
          "refId": "D"
        }
      ]
    }

  ]
}
