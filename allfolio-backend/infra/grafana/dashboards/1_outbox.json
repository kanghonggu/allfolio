{
  "title": "Outbox 상태",
  "uid": "allfolio-outbox",
  "tags": ["allfolio", "outbox"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Pending 이벤트",
      "options": { "colorMode": "background", "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 100 },
        { "color": "red",    "value": 1000 }
      ]}},
      "targets": [{ "expr": "outbox_pending_size", "legendFormat": "pending" }]
    },
    {
      "id": 2, "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Failed 이벤트",
      "options": { "colorMode": "background", "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 10 },
        { "color": "red",    "value": 100 }
      ]}},
      "targets": [{ "expr": "outbox_failed_size", "legendFormat": "failed" }]
    },
    {
      "id": 3, "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Dead 이벤트",
      "options": { "colorMode": "background", "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "red",   "value": 1 }
      ]}},
      "targets": [{ "expr": "outbox_dead_size", "legendFormat": "dead" }]
    },
    {
      "id": 4, "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "type": "stat",
      "title": "처리 성공률 (5m)",
      "options": { "unit": "percentunit" },
      "targets": [{ "expr": "rate(outbox_event_count_total{result='processed'}[5m]) / (rate(outbox_event_count_total[5m]) + 1e-9)", "legendFormat": "success rate" }]
    },
    {
      "id": 5, "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Outbox 처리 TPS",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(outbox_event_count_total{result='processed'}[1m])", "legendFormat": "processed" },
        { "expr": "rate(outbox_event_count_total{result='failed'}[1m])",    "legendFormat": "failed" },
        { "expr": "rate(outbox_event_count_total{result='dead'}[1m])",      "legendFormat": "dead" }
      ]
    },
    {
      "id": 6, "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Outbox 처리 레이턴시 (p50/p95/p99)",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(outbox_process_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(outbox_process_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(outbox_process_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99" }
      ],
      "alert": {
        "name": "outbox_latency_high",
        "message": "Outbox processing latency p95 > 1s",
        "conditions": [{ "type": "query", "query": { "params": ["A", "5m", "now"] }, "reducer": { "type": "last" }, "evaluator": { "type": "gt", "params": [1000] } }]
      }
    }
  ]
}
